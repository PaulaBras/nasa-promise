        <mxCell id="28" value="&lt;b&gt;XGBoost&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#555&quot;&gt;500 trees, depth 5&lt;br&gt;scale_pos_weight=5.62&lt;br&gt;&lt;b&gt;AUC 0.767 | F1 0.431&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C62828;fontColor=#1a1a2e;arcSize=15;shadow=1;" parent="1" vertex="1">
