        <mxCell id="34" value="&lt;b&gt;6. Soft-Voting Ensemble (V2-E)&lt;/b&gt;" style="text;html=1;align=left;fontSize=13;fontColor=#F57F17;" parent="1" vertex="1">
          <mxGeometry x="60" y="720" width="280" height="25" as="geometry" />
        </mxCell>
        <mxCell id="35" value="&lt;b&gt;Soft-Voting Ensemble&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#555&quot;&gt;p = (p_xgboost + p_rf) / 2&lt;br&gt;Diverse models → better predictions&lt;br&gt;&lt;b style=&quot;color:#2E7D32&quot;&gt;AUC 0.771 | F1 0.434 ✓ Best&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontColor=#1a1a2e;arcSize=15;shadow=1;strokeWidth=2;" parent="1" vertex="1">
