        <mxCell id="42" value="&lt;font color=&quot;#555&quot;&gt;⚠ &lt;b&gt;Class Imbalance:&lt;/b&gt; only ~15% defective&lt;br&gt;Handled via scale_pos_weight &amp;amp; class_weight=balanced&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#FF8F00;shadow=1;fontColor=#1a1a2e;fontSize=11;" parent="1" vertex="1">
