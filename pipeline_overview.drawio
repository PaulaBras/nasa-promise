        <mxCell id="24" value="&lt;b&gt;4. Cross-Validation (V2-A)&lt;/b&gt;" style="text;html=1;align=left;fontSize=13;fontColor=#6A1B9A;" parent="1" vertex="1">
          <mxGeometry x="60" y="460" width="300" height="25" as="geometry" />
        </mxCell>
        <mxCell id="25" value="&lt;b&gt;Repeated Stratified K-Fold&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#555&quot;&gt;5 splits × 5 repeats = 25 evaluations&lt;br&gt;Preserves ~15% defect rate per fold&lt;br&gt;Most stable CV estimate&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#6A1B9A;fontColor=#1a1a2e;arcSize=15;shadow=1;" parent="1" vertex="1">
