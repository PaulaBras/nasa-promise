        <mxCell id="27" value="&lt;b&gt;5. Model Training &amp;amp; Comparison (V2-D)&lt;/b&gt;" style="text;html=1;align=left;fontSize=13;fontColor=#BF360C;" parent="1" vertex="1">
          <mxGeometry x="60" y="585" width="320" height="25" as="geometry" />
