        <mxCell id="17" value="&lt;b&gt;3. Feature Engineering (V2-B)&lt;/b&gt;" style="text;html=1;align=left;fontSize=13;fontColor=#2E7D32;" parent="1" vertex="1">
          <mxGeometry x="60" y="325" width="260" height="25" as="geometry" />
        </mxCell>
        <mxCell id="18" value="&lt;b&gt;log1p Transform&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#555&quot;&gt;Compress skewed metrics&lt;br&gt;(e.g. Halstead effort 1→870k)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontColor=#1a1a2e;arcSize=15;shadow=1;" parent="1" vertex="1">
          <mxGeometry x="60" y="370" width="220" height="65" as="geometry" />
        </mxCell>
        <mxCell id="19" value="&lt;b&gt;RobustScaler&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#555&quot;&gt;Centre by median, scale by IQR&lt;br&gt;Outlier-resistant&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontColor=#1a1a2e;arcSize=15;shadow=1;" parent="1" vertex="1">
          <mxGeometry x="320" y="370" width="210" height="65" as="geometry" />
        </mxCell>
        <mxCell id="20" value="&lt;b&gt;Interaction Features&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#555&quot;&gt;ratio_ev_vg = ev(g)/v(g)&lt;br&gt;ratio_loc_n = loc/n&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontColor=#1a1a2e;arcSize=15;shadow=1;" parent="1" vertex="1">
